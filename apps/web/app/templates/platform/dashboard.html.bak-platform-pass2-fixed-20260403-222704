{% set platform_page = "dashboard" %}
{% set page_title = "FutureFunded Dashboard" %}
{% set page_description = "Operate your FutureFunded workspace from one premium dashboard — manage organizations, campaigns, sponsor packages, and memberships with a cleaner command-center experience." %}
{% extends "platform/base.html" %}
{% block platform_content %}
<section class="ff-section" aria-labelledby="platformDashboardTitle">
  <div class="ff-container">

    <div class="ff-grid ff-grid--2 ff-gap-3 ff-platformGridTop">
      <header class="ff-sectionhead ff-sectionhead--flagship ff-sectionhead--compact">
        <div class="ff-sectionhead__text ff-minw-0">
          <p class="ff-kicker ff-m-0">Admin dashboard</p>

          <h1
            class="ff-display ff-mt-2 ff-mb-0 ff-measure-12"
            id="platformDashboardTitle"
          >
            FutureFunded command center
          </h1>

          <p class="ff-lead ff-mt-3 ff-mb-0 ff-measure-42">
            Manage the live Connect ATX Elite fundraiser, sponsor packages, and recurring booster support from one premium workspace.
          </p>

          <div class="ff-row ff-wrap ff-gap-2 ff-mt-3" role="list" aria-label="Workspace qualities">
            <span class="ff-pill ff-pill--soft" role="listitem">Live workspace</span>
            <span class="ff-pill ff-pill--soft" role="listitem">Brand-ready</span>
            <span class="ff-pill ff-pill--ghost" role="listitem">Operator view</span>
          </div>
        </div>
      </header>

      <aside class="ff-card ff-glass ff-pad" aria-labelledby="platformWorkspaceBriefTitle">
        <p class="ff-kicker ff-m-0">Workspace brief</p>
        <h2 class="ff-h2 ff-mt-2 ff-mb-0" id="platformWorkspaceBriefTitle">One place to launch, manage, and expand.</h2>
        <p class="ff-help ff-muted ff-mt-2 ff-mb-0">
          This dashboard is your control layer for live fundraising, sponsor packages, and recurring support lanes.
        </p>

        <div class="ff-platformMiniList ff-mt-3">
          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Live campaign</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Connect ATX Elite is already launched with a public campaign page and dashboard access.</p>
          </article>

          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Sponsor lanes</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Manage sponsor packages that feel credible to local businesses and community partners.</p>
          </article>

          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Recurring support</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Keep momentum going beyond one-time gifts with monthly and annual memberships.</p>
          </article>
        </div>
      </aside>
    </div>

    <div class="ff-grid ff-grid--3 ff-gap-3 ff-mt-3" aria-label="Revenue snapshot">
      <article class="ff-card ff-glass ff-pad" aria-labelledby="platformRevenueRaisedTitle">
        <p class="ff-kicker ff-m-0">Revenue snapshot</p>
        <h2 class="ff-h2 ff-mt-2 ff-mb-0" id="platformRevenueRaisedTitle">$175 raised</h2>
        <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Current public support already flowing through the live fundraiser.</p>
      </article>

      <article class="ff-card ff-glass ff-pad" aria-labelledby="platformRevenueSponsorsTitle">
        <p class="ff-kicker ff-m-0">Active sponsors</p>
        <h2 class="ff-h2 ff-mt-2 ff-mb-0" id="platformRevenueSponsorsTitle">2 lanes live</h2>
        <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Sponsor packages are positioned as real local-business offers.</p>
      </article>

      <article class="ff-card ff-glass ff-pad" aria-labelledby="platformRevenueMembershipsTitle">
        <p class="ff-kicker ff-m-0">Recurring support</p>
        <h2 class="ff-h2 ff-mt-2 ff-mb-0" id="platformRevenueMembershipsTitle">$19/mo starter</h2>
        <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Membership lanes extend value beyond a single campaign push.</p>
      </article>
    </div>

    <div class="ff-grid ff-grid--2 ff-gap-3 ff-mt-3">
      <article class="ff-card ff-glass ff-pad ff-platformPanel" aria-labelledby="platformOverviewTitle">
        <header class="ff-platformPanel__head">
          <div class="ff-row ff-row--between ff-ais ff-wrap ff-gap-2">
            <h2 class="ff-h2 ff-m-0" id="platformOverviewTitle">Overview</h2>
            <span class="ff-platformInlinePill">Live workspace</span>
          </div>
          <p class="ff-help ff-muted ff-mt-2 ff-mb-0">
            Core inventory across the current FutureFunded operator surface.
          </p>
        </header>

        <div class="ff-platformMetricGrid ff-mt-3">
          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Organizations</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Total active org records in your workspace</p>
            <span class="ff-platformStatPill">1</span>
          </article>

          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Campaigns</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Fundraising campaigns available to manage</p>
            <span class="ff-platformStatPill">1</span>
          </article>

          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Sponsor tiers</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Packages available for brand partners</p>
            <span class="ff-platformStatPill">2</span>
          </article>

          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Membership plans</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Recurring supporter plans configured</p>
            <span class="ff-platformStatPill">2</span>
          </article>
        </div>
      </article>

      <article class="ff-card ff-glass ff-pad ff-platformPanel" aria-labelledby="platformActionsTitle">
        <header class="ff-platformPanel__head">
          <div class="ff-row ff-row--between ff-ais ff-wrap ff-gap-2">
            <h2 class="ff-h2 ff-m-0" id="platformActionsTitle">Next actions</h2>
            <span class="ff-platformInlinePill">Launch-ready</span>
          </div>
          <p class="ff-help ff-muted ff-mt-2 ff-mb-0">
            Jump directly into the most likely operator tasks.
          </p>
        </header>

        <div class="ff-row ff-wrap ff-gap-2 ff-mt-3">
          <a class="ff-btn ff-btn--primary ff-btn--pill" href="/platform/onboarding">Create another org</a>
          <a class="ff-btn ff-btn--secondary ff-btn--pill" href="/c/spring-fundraiser">Open live campaign</a>
          <a class="ff-btn ff-btn--secondary ff-btn--pill" href="/c/spring-fundraiser">Open campaign page</a>
        </div>

        <article class="ff-proofMini ff-mt-3" aria-labelledby="platformLatestLiveOrgTitle">
          <p class="ff-kicker ff-m-0">Latest live organization</p>
          <h3 class="ff-h3 ff-mt-2 ff-mb-0" id="platformLatestLiveOrgTitle">Connect ATX Elite</h3>
          <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Spring Fundraiser</p>

          <div class="ff-row ff-wrap ff-gap-2 ff-mt-3">
            <span class="ff-platformInlinePill">Live</span>
            <span class="ff-platformInlinePill">Brand-ready</span>
            <a class="ff-platformInlinePill" href="/c/spring-fundraiser">Open live page</a>
          </div>
        </article>

        <div class="ff-platformMiniList ff-mt-3">
          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Next best action</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Add or refine a sponsor package next. That is the fastest way to turn this from a fundraiser into a broader revenue system.</p>
          </article>

          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Operator note</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">The current workspace is already structured for direct giving, sponsor upsells, and recurring support expansion.</p>
          </article>
        </div>
      </article>
    </div>

    <div class="ff-grid ff-grid--2 ff-gap-3 ff-mt-3">
      <article class="ff-card ff-glass ff-pad ff-platformPanel" aria-labelledby="platformSponsorTitle">
        <header class="ff-platformPanel__head">
          <div class="ff-row ff-row--between ff-ais ff-wrap ff-gap-2">
            <h2 class="ff-h2 ff-m-0" id="platformSponsorTitle">Sponsor tiers</h2>
            <span class="ff-platformInlinePill">Revenue lane</span>
          </div>
          <p class="ff-help ff-muted ff-mt-2 ff-mb-0">
            Current sponsor packages positioned for local business support and program visibility.
          </p>
        </header>

        <div class="ff-platformMiniList ff-mt-3">
          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Bronze Sponsor</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Entry-tier local sponsor visibility.</p>
            <div class="ff-row ff-wrap ff-gap-2 ff-mt-3">
              <span class="ff-platformInlinePill">$250.00</span>
              <span class="ff-platformInlinePill">Active</span>
              <span class="ff-platformInlinePill">Starter lane</span>
            </div>
          </article>

          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Gold Sponsor</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Premium sponsor placement and recognition.</p>
            <div class="ff-row ff-wrap ff-gap-2 ff-mt-3">
              <span class="ff-platformInlinePill">$1000.00</span>
              <span class="ff-platformInlinePill">Featured</span>
              <span class="ff-platformInlinePill">Active</span>
            </div>
          </article>
        </div>
      </article>

      <article class="ff-card ff-glass ff-pad ff-platformPanel" aria-labelledby="platformMembershipTitle">
        <header class="ff-platformPanel__head">
          <div class="ff-row ff-row--between ff-ais ff-wrap ff-gap-2">
            <h2 class="ff-h2 ff-m-0" id="platformMembershipTitle">Membership plans</h2>
            <span class="ff-platformInlinePill">Recurring lane</span>
          </div>
          <p class="ff-help ff-muted ff-mt-2 ff-mb-0">
            Recurring support options designed to keep the program moving beyond a single campaign push.
          </p>
        </header>

        <div class="ff-platformMiniList ff-mt-3">
          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Booster Monthly</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Monthly support for the program.</p>
            <div class="ff-row ff-wrap ff-gap-2 ff-mt-3">
              <span class="ff-platformInlinePill">$19.00</span>
              <span class="ff-platformInlinePill">monthly</span>
            </div>
          </article>

          <article class="ff-proofMini">
            <p class="ff-kicker ff-m-0">Booster Annual</p>
            <p class="ff-help ff-muted ff-mt-2 ff-mb-0">Annual support with premium recognition.</p>
            <div class="ff-row ff-wrap ff-gap-2 ff-mt-3">
              <span class="ff-platformInlinePill">$199.00</span>
              <span class="ff-platformInlinePill">yearly</span>
              <span class="ff-platformInlinePill">Featured</span>
            </div>
          </article>
        </div>
      </article>
    </div>

  </div>
</section>

    <div class="ff-card ff-glass ff-pad ff-mt-3" aria-labelledby="platformRevenueFocusTitle">
      <div class="ff-row ff-row--between ff-ais ff-wrap ff-gap-2">
        <div class="ff-minw-0">
          <p class="ff-kicker ff-m-0">Revenue focus</p>
          <h2 class="ff-h2 ff-mt-2 ff-mb-0" id="platformRevenueFocusTitle">The next money move is sponsor conversion.</h2>
          <p class="ff-help ff-muted ff-mt-2 ff-mb-0">
            Direct giving gets the fundraiser live. Sponsor packages and recurring memberships are what turn it into a longer-term revenue system.
          </p>
        </div>
        <div class="ff-row ff-wrap ff-gap-2">
          <a class="ff-btn ff-btn--primary ff-btn--pill" href="/c/spring-fundraiser#sponsors">Open sponsor section</a>
          <a class="ff-btn ff-btn--secondary ff-btn--pill" href="/platform/onboarding">Create another launch</a>
        </div>
      </div>
    </div>

    <div class="ff-grid ff-grid--2 ff-gap-3 ff-mt-3" aria-labelledby="platformPlanCardTitle">
      <article class="ff-card ff-glass ff-pad" aria-labelledby="platformPlanCardTitle">
        <p class="ff-kicker ff-m-0">Revenue plan</p>
        <h2 class="ff-h2 ff-mt-2 ff-mb-0" id="platformPlanCardTitle">Start with direct giving. Expand with sponsor lanes.</h2>
        <p class="ff-help ff-muted ff-mt-2 ff-mb-0">
          The cleanest operator path is: launch the fundraiser, activate sponsor packages, then add recurring memberships once the program has momentum.
        </p>
      </article>

      <article class="ff-card ff-glass ff-pad" aria-labelledby="platformCommercialMoveTitle">
        <p class="ff-kicker ff-m-0">Commercial move</p>
        <h2 class="ff-h2 ff-mt-2 ff-mb-0" id="platformCommercialMoveTitle">Use this workspace to sell the next org.</h2>
        <p class="ff-help ff-muted ff-mt-2 ff-mb-0">
          The strongest pitch is showing that FutureFunded already powers a live fundraiser, sponsor-ready offers, and an operator dashboard from one branded system.
        </p>
      </article>
    </div>

    <div class="ff-card ff-glass ff-pad ff-mt-3" aria-labelledby="platformSalesOpsTitle">
      <div class="ff-row ff-row--between ff-ais ff-wrap ff-gap-2">
        <div class="ff-minw-0">
          <p class="ff-kicker ff-m-0">Sales operator note</p>
          <h2 class="ff-h2 ff-mt-2 ff-mb-0" id="platformSalesOpsTitle">This dashboard is part of the sales pitch.</h2>
          <p class="ff-help ff-muted ff-mt-2 ff-mb-0">
            The strongest demo is showing that one org can launch a public fundraiser, activate sponsor-ready lanes, and manage everything from one branded operator surface.
          </p>
        </div>
        <div class="ff-row ff-wrap ff-gap-2">
          <a class="ff-btn ff-btn--primary ff-btn--pill" href="/platform/">Open platform home</a>
          <a class="ff-btn ff-btn--secondary ff-btn--pill" href="/c/spring-fundraiser">Open live fundraiser</a>
        </div>
      </div>
    </div>
{% endblock %}
