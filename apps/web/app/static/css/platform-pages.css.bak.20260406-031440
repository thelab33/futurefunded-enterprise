/* ==========================================================================
   FF_PLATFORM_PASS4_ENTERPRISE_SURFACES
   ========================================================================== */
@layer ff.pages {
  body[data-ff-page="platform-onboarding"] .ff-sectionhead,
  body[data-ff-page="platform-dashboard"] .ff-sectionhead {
    margin-bottom: 0.25rem;
  }

  .ff-platformFormGrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    align-items: start;
  }

  .ff-platformFormCard,
  .ff-platformPanel {
    display: grid;
    gap: 0.9rem;
    min-height: 100%;
  }

  .ff-platformFormCard__head,
  .ff-platformPanel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .ff-platformFieldGrid {
    display: grid;
    gap: 0.95rem;
  }

  .ff-platformFieldGrid .ff-input {
    min-height: 3.45rem;
    border-radius: 1rem;
  }

  .ff-platformMiniList {
    display: grid;
    gap: 0.9rem;
  }

  .ff-platformStatPill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
  }

  @media (max-width: 71.99rem) {
    .ff-platformFormGrid {
      grid-template-columns: 1fr;
    }
  }
}

/* FF_PLATFORM_PASS4_ENTERPRISE_SURFACES_END */

/* FF_PLATFORM_PRESTIGE_V1_START */
@layer ff.pages {
  body[data-ff-template="platform"] {
    --ff-platform-shell-max: 1200px;
    --ff-platform-card-radius: 28px;
    --ff-platform-card-border: rgba(255, 255, 255, 0.08);
    --ff-platform-card-bg-top: rgba(19, 32, 68, 0.72);
    --ff-platform-card-bg-bottom: rgba(9, 18, 38, 0.9);
    --ff-platform-shadow: 0 18px 44px rgba(0, 0, 0, 0.22);
  }

  body[data-ff-template="platform"] .ff-container {
    width: min(100% - 2rem, var(--ff-platform-shell-max));
  }

  body[data-ff-template="platform"] .ff-main {
    padding-bottom: clamp(3rem, 2rem + 2vw, 5rem);
  }

  body[data-ff-template="platform"] .ff-section {
    --ff-space-section: clamp(1.5rem, 1.05rem + 1.2vw, 2.75rem);
  }

  body[data-ff-template="platform"] .ff-sectionhead__text > .ff-lead {
    max-width: 42ch;
  }

  body[data-ff-template="platform"] .ff-card.ff-glass,
  body[data-ff-template="platform"] .ff-proofMini {
    border-radius: var(--ff-platform-card-radius);
    border: 1px solid var(--ff-platform-card-border);
    background:
      linear-gradient(180deg, var(--ff-platform-card-bg-top), var(--ff-platform-card-bg-bottom));
    box-shadow: var(--ff-platform-shadow);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  body[data-ff-template="platform"] .ff-card.ff-glass {
    padding: clamp(1rem, 0.9rem + 0.6vw, 1.45rem);
  }

  body[data-ff-template="platform"] .ff-proofMini {
    padding: clamp(0.95rem, 0.84rem + 0.45vw, 1.15rem);
  }

  body[data-ff-template="platform"] .ff-proofMini .ff-kicker {
    letter-spacing: 0.06em;
  }

  body[data-ff-template="platform"] .ff-platformPanel__head,
  body[data-ff-template="platform"] .ff-platformFormCard__head {
    display: grid;
    gap: 0.25rem;
  }

  body[data-ff-template="platform"] .ff-platformMiniList {
    display: grid;
    gap: clamp(0.8rem, 0.72rem + 0.35vw, 1rem);
  }

  body[data-ff-template="platform"] .ff-platformMetricGrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.8rem, 0.72rem + 0.35vw, 1rem);
  }

  body[data-ff-template="platform"] .ff-platformStatPill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.9rem;
    min-width: 2.4rem;
    min-height: 2.4rem;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.06);
    font-weight: 800;
    line-height: 1;
  }

  body[data-ff-template="platform"] .ff-platformInlinePill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.05);
    color: inherit;
    text-decoration: none;
    font-size: 0.88rem;
    line-height: 1;
    white-space: nowrap;
  }

  body[data-ff-template="platform"] .ff-label {
    letter-spacing: 0.06em;
  }

  body[data-ff-template="platform"] .ff-platformFieldGrid {
    display: grid;
    gap: 1rem;
  }

  body[data-ff-template="platform"] .ff-input {
    min-height: 3.25rem;
    border-radius: 18px;
    border-color: rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(10, 22, 49, 0.85), rgba(7, 15, 34, 0.92));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  body[data-ff-template="platform"] .ff-input:focus-visible {
    outline: none;
    box-shadow:
      0 0 0 3px rgba(249, 115, 22, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  body[data-ff-template="platform"] .ff-platformCtaBar {
    margin-top: clamp(1rem, 0.85rem + 0.45vw, 1.35rem);
    display: grid;
    gap: 0.3rem;
  }

  body[data-ff-template="platform"] .ff-btn.ff-btn--pill {
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
  }

  body[data-ff-template="platform"] .ff-nav.ff-nav--pill {
    padding: 0.35rem;
    border-radius: 999px;
  }

  body[data-ff-template="platform"] .ff-nav.ff-nav--pill .ff-nav__link {
    min-height: 2.4rem;
    padding-inline: 1rem;
    border-radius: 999px;
  }

  body[data-ff-template="platform"] .ff-platformBrand {
    gap: 0.85rem;
  }

  body[data-ff-template="platform"] .ff-platformBrand__disc {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.08),
      0 12px 28px rgba(249, 115, 22, 0.22);
  }

  @media (max-width: 900px) {
    body[data-ff-template="platform"] .ff-platformMetricGrid {
      grid-template-columns: 1fr;
    }

    body[data-ff-template="platform"] .ff-card.ff-glass {
      padding: 1rem;
    }

    body[data-ff-template="platform"] .ff-proofMini {
      padding: 0.9rem;
    }
  }

  @media (max-width: 640px) {
    body[data-ff-template="platform"] .ff-container {
      width: min(100% - 1rem, var(--ff-platform-shell-max));
    }

    body[data-ff-template="platform"] .ff-section {
      --ff-space-section: 1.1rem;
    }

    body[data-ff-template="platform"] .ff-display {
      letter-spacing: -0.04em;
    }

    body[data-ff-template="platform"] .ff-nav.ff-nav--pill {
      width: 100%;
      justify-content: space-between;
      overflow-x: auto;
    }

    body[data-ff-template="platform"] .ff-nav.ff-nav--pill .ff-nav__link {
      padding-inline: 0.9rem;
      white-space: nowrap;
    }

    body[data-ff-template="platform"] .ff-btn.ff-btn--pill {
      width: auto;
    }
  }
}

/* FF_PLATFORM_PRESTIGE_V1_END */

/* FF_PLATFORM_CLEANUP_PASS1_START */
body[data-ff-platform="true"] .ff-platformChrome__inner {
  padding-top: 1.25rem;
}

body[data-ff-platform="true"] .ff-platformBrand__subline {
  display: block;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

body[data-ff-platform="true"] .ff-platformGridTop {
  align-items: start;
}

body[data-ff-platform="true"] .ff-measure-10 {
  max-width: 10ch;
}

body[data-ff-platform="true"] .ff-measure-11 {
  max-width: 11ch;
}

body[data-ff-platform="true"] .ff-measure-12 {
  max-width: 12ch;
}

body[data-ff-platform="true"] .ff-measure-36 {
  max-width: 36ch;
}

body[data-ff-platform="true"] .ff-measure-38 {
  max-width: 38ch;
}

body[data-ff-platform="true"] .ff-measure-42 {
  max-width: 42ch;
}

/* FF_PLATFORM_CLEANUP_PASS1_END */

/* ==========================================================================
   FF_PLATFORM_RUNTIME_CONVERGENCE_V1
   Platform runtime ownership + premium polish
   - fills missing platform contract class
   - tightens shell chrome and brand cluster
   - refines platform mini-list / proof cards
   - adds light surface-aware polish
   ========================================================================== */

body[data-ff-platform="true"] .ff-platformChrome__inner {
  display: grid;
  gap: clamp(0.875rem, 1.2vw, 1.25rem);
  align-items: stretch;
}

body[data-ff-platform="true"] .ff-platformBrand {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  min-width: 0;
}

body[data-ff-platform="true"] .ff-platformBrand__disc {
  flex: 0 0 auto;
}

body[data-ff-platform="true"] .ff-platformBrand__wordmark {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.1rem;
  min-width: 0;
  line-height: 1.05;
}

body[data-ff-platform="true"] .ff-platformBrand__subline {
  white-space: nowrap;
}

body[data-ff-platform="true"] .ff-platformGridTop {
  align-items: stretch;
}

body[data-ff-platform="true"] .ff-platformMiniList {
  display: grid;
  gap: 0.875rem;
}

body[data-ff-platform="true"] .ff-proofMini {
  position: relative;
  border-radius: 1rem;
  padding: 0.95rem 1rem;
  background: color-mix(in srgb, var(--ff-surface, #111827) 82%, transparent);
  border: 1px solid color-mix(in srgb, var(--ff-border, #334155) 74%, transparent);
  box-shadow: 0 8px 24px rgba(2, 6, 23, 0.08);
}

body[data-ff-platform="true"] .ff-platformInlinePill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 2rem;
  padding: 0.35rem 0.7rem;
  border-radius: 999px;
  font-weight: 700;
  letter-spacing: 0.01em;
}

body[data-ff-platform="true"][data-ff-platform-surface="marketing"] .ff-platformChrome__inner {
  gap: clamp(0.875rem, 1.4vw, 1.35rem);
}

body[data-ff-platform="true"][data-ff-platform-surface="operator"] .ff-platformChrome__inner {
  gap: clamp(0.75rem, 1.1vw, 1.1rem);
}

body[data-ff-platform="true"][data-ff-platform-surface="marketing"] .ff-proofMini {
  background: color-mix(in srgb, var(--ff-surface, #111827) 80%, transparent);
}

body[data-ff-platform="true"][data-ff-platform-surface="operator"] .ff-proofMini {
  background: color-mix(in srgb, var(--ff-surface, #111827) 88%, transparent);
}

@media (max-width: 820px) {
  body[data-ff-platform="true"] .ff-platformBrand {
    gap: 0.625rem;
  }

  body[data-ff-platform="true"] .ff-platformMiniList {
    gap: 0.75rem;
  }

  body[data-ff-platform="true"] .ff-proofMini {
    padding: 0.875rem 0.875rem;
    border-radius: 0.9rem;
  }

  body[data-ff-platform="true"] .ff-platformBrand__subline {
    white-space: normal;
  }
}
