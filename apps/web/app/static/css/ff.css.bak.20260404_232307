      max-height: min(94dvh, 64rem);
    }

    .ff-checkoutShell {
      padding: 1.15rem;
    }
  }

  @media (min-width: 64rem) {
    .ff-topbar__desktop-only {
      display: block;
    }

    .ff-topbar__mobile-only {
      display: none;
    }

    .ff-hero__grid {
      grid-template-columns: minmax(0, 1.16fr) minmax(20rem, 0.84fr);
      gap: 1rem;
    }

    .ff-impactLayout,
    .ff-storyGrid,
    .ff-checkoutLayout--form {
      grid-template-columns: minmax(0, 1.06fr) minmax(18rem, 0.94fr);
      gap: 1rem;
    }

    .ff-footerGrid {
      grid-template-columns: minmax(0, 1.15fr) minmax(16rem, 0.85fr);
    }

    .ff-impactTierGrid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .ff-teamGrid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ff-sponsorWallRail {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .ff-sheet__panel {
      justify-self: center;
      width: min(100%, 78rem);
      border-radius: 1.5rem;
      margin: 1rem;
    }

    .ff-checkoutShell {
      border-radius: 1.25rem;
    }

    .ff-checkoutLayout--success {
      grid-template-columns: minmax(0, 1fr);
    }

    .ff-modal__panel--video .ff-videoMount,
    .ff-modal__panel--video .ff-skeleton--video {
      min-height: min(42vw, 38rem);
    }
  }

  @media (max-width: 47.99rem) {
    .ff-topbarGoal__summary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ff-topbarGoal__metric--progress {
      grid-column: 1 / -1;
    }

    .ff-teamCard__stats {
      grid-template-columns: 1fr;
    }

    .ff-backtotop {
      right: 0.75rem;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .ff-card:hover,
    .ff-impactTier:hover,
    .ff-teamCard:hover,
    .ff-sponsorCell:hover,
    .ff-checkoutCard:hover,
    .ff-disclosure:hover {
      box-shadow: var(--ff-shadow-2);
    }
  }
}
