/* ==========================================================================
   FutureFunded — ff.css
   Version: v6.0.0 "Unified Fundraiser Authority"
   --------------------------------------------------------------------------
   Scope:
   - canonical fundraiser authority file
   - mobile-first, accessible, reduced-motion safe
   - premium glass / flagship fundraising presentation
   - single-source ownership for the campaign surface
   ========================================================================== */

@layer ff.tokens, ff.base, ff.layout, ff.components, ff.sections, ff.overlays, ff.utilities;

/* ==========================================================================
   TOKENS
   ========================================================================== */
@layer ff.tokens {
  :root,
  html.ff-root {
    color-scheme: light;

    --ff-font-sans: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    --ff-font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;

    --ff-bg: #edf3f8;
    --ff-bg-soft: #f7fafd;
    --ff-bg-elev: #ffffff;
    --ff-panel: rgb(255 255 255 / 0.76);
    --ff-panel-strong: rgb(255 255 255 / 0.9);
    --ff-panel-solid: #ffffff;

    --ff-text: #0f172a;
    --ff-text-soft: #1f3144;
    --ff-text-muted: #5f6f84;
    --ff-text-faint: #7a8798;
    --ff-inverse: #ffffff;

    --ff-brand: #f97316;
    --ff-brand-strong: #ea580c;
    --ff-brand-soft: rgb(249 115 22 / 0.12);

    --ff-accent: #0f766e;
    --ff-accent-soft: rgb(15 118 110 / 0.12);

    --ff-info: #0ea5e9;
    --ff-info-soft: rgb(14 165 233 / 0.12);
    --ff-success: #0f766e;
    --ff-success-soft: rgb(15 118 110 / 0.12);
    --ff-danger: #b91c1c;
    --ff-danger-soft: rgb(185 28 28 / 0.1);

    --ff-border: rgb(15 23 42 / 0.1);
    --ff-border-strong: rgb(15 23 42 / 0.14);
    --ff-line: rgb(15 23 42 / 0.08);

    --ff-shadow-1:
      0 1px 2px rgb(15 23 42 / 0.04),
      0 10px 24px rgb(15 23 42 / 0.05);
    --ff-shadow-2:
      0 10px 30px rgb(15 23 42 / 0.08),
      0 2px 10px rgb(15 23 42 / 0.04);
    --ff-shadow-3:
      0 20px 60px rgb(15 23 42 / 0.14),
      0 8px 20px rgb(15 23 42 / 0.06);
    --ff-shadow-focus:
      0 0 0 2px var(--ff-bg),
      0 0 0 4px rgb(14 165 233 / 0.3);

    --ff-radius-1: 0.75rem;
    --ff-radius-2: 1rem;
    --ff-radius-3: 1.25rem;
    --ff-radius-4: 1.5rem;
    --ff-pill: 999px;

    --ff-0: 0;
    --ff-1: 0.25rem;
    --ff-2: 0.5rem;
    --ff-3: 0.75rem;
    --ff-4: 1rem;
    --ff-5: 1.25rem;
    --ff-6: 1.5rem;
    --ff-7: 2rem;
    --ff-8: 2.5rem;
    --ff-9: 3rem;
    --ff-10: 4rem;

    --ff-max: 76rem;
    --ff-max-wide: 82rem;
    --ff-safe-top: env(safe-area-inset-top, 0px);
    --ff-safe-right: env(safe-area-inset-right, 0px);
    --ff-safe-bottom: env(safe-area-inset-bottom, 0px);
    --ff-safe-left: env(safe-area-inset-left, 0px);

    --ff-header-offset: 6rem;
    --ff-tabs-offset: 4.5rem;
    --ff-blur: 18px;

    --ff-space-card: clamp(0.9rem, 0.82rem + 0.35vw, 1.12rem);
    --ff-space-grid: clamp(0.85rem, 0.78rem + 0.32vw, 1rem);
    --ff-space-section: clamp(1.7rem, 1.25rem + 1.5vw, 3rem);

    --ff-display-size: clamp(2.2rem, 7vw, 4.5rem);
    --ff-h2-size: clamp(1.35rem, 2.2vw, 2rem);
    --ff-h3-size: clamp(1rem, 1.35vw, 1.22rem);

    --ff-ease: 180ms cubic-bezier(.2, .7, .2, 1);
    --ff-ease-emph: 260ms cubic-bezier(.16, 1, .3, 1);

    --ff-bg-glow-a: rgb(14 165 233 / 0.05);
    --ff-bg-glow-b: rgb(249 115 22 / 0.065);
  }

  html.ff-root[data-theme="dark"] {
    color-scheme: dark;

    --ff-bg: #09121f;
    --ff-bg-soft: #0d1727;
    --ff-bg-elev: #101a2b;
    --ff-panel: rgb(9 17 30 / 0.76);
    --ff-panel-strong: rgb(11 20 35 / 0.9);
    --ff-panel-solid: #111c2d;

    --ff-text: #edf4ff;
    --ff-text-soft: #dfe9f7;
    --ff-text-muted: #b6c4d8;
    --ff-text-faint: #91a0b7;

    --ff-border: rgb(226 232 240 / 0.11);
    --ff-border-strong: rgb(226 232 240 / 0.16);
    --ff-line: rgb(226 232 240 / 0.1);

    --ff-brand-soft: rgb(249 115 22 / 0.18);
    --ff-accent-soft: rgb(15 118 110 / 0.18);
    --ff-info-soft: rgb(14 165 233 / 0.18);
    --ff-success-soft: rgb(15 118 110 / 0.18);
    --ff-danger-soft: rgb(239 68 68 / 0.16);

    --ff-shadow-1:
      0 1px 0 rgb(255 255 255 / 0.03) inset,
      0 10px 24px rgb(0 0 0 / 0.24);
    --ff-shadow-2:
      0 1px 0 rgb(255 255 255 / 0.04) inset,
      0 18px 40px rgb(0 0 0 / 0.34);
    --ff-shadow-3:
      0 1px 0 rgb(255 255 255 / 0.05) inset,
      0 28px 80px rgb(0 0 0 / 0.46);

    --ff-bg-glow-a: rgb(14 165 233 / 0.09);
    --ff-bg-glow-b: rgb(249 115 22 / 0.12);
  }

  html.ff-root[data-ff-theme="signal-glass"] {
    --ff-brand: #7c3aed;
    --ff-brand-strong: #6d28d9;
    --ff-brand-soft: rgb(124 58 237 / 0.16);
    --ff-info: #38bdf8;
  }

  html.ff-root[data-ff-theme="school-spirit"] {
    --ff-brand: #dc2626;
    --ff-brand-strong: #b91c1c;
    --ff-brand-soft: rgb(220 38 38 / 0.13);
    --ff-accent: #ca8a04;
    --ff-info: #2563eb;
  }
}

/* ==========================================================================
   BASE
   ========================================================================== */
@layer ff.base {
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html.ff-root {
    background: var(--ff-bg);
    overflow-x: clip;
    scroll-behavior: smooth;
    scroll-padding-top: calc(var(--ff-header-offset) + var(--ff-safe-top));
    text-size-adjust: 100%;
  }

  @supports not (overflow: clip) {
    html.ff-root {
      overflow-x: hidden;
    }
  }

  body.ff-body {
    min-width: 320px;
    min-height: 100dvh;
    margin: 0;
    color: var(--ff-text);
    font-family: var(--ff-font-sans);
    line-height: 1.55;
    background:
      radial-gradient(circle at 10% 0%, var(--ff-bg-glow-a), transparent 24rem),
      radial-gradient(circle at 100% 0%, var(--ff-bg-glow-b), transparent 24rem),
      linear-gradient(180deg, var(--ff-bg-soft), var(--ff-bg));
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
    accent-color: var(--ff-brand);
  }

  main,
  section,
  article,
  aside,
  footer,
  header,
  nav,
  div {
    min-width: 0;
  }

  img,
  picture,
  svg,
  video,
  canvas {
    display: block;
    max-width: 100%;
  }

  img {
    height: auto;
  }

  a {
    color: inherit;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.14em;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
    color: inherit;
  }

  button {
    cursor: pointer;
  }

  progress {
    appearance: none;
    -webkit-appearance: none;
  }

  [id] {
    scroll-margin-top: calc(var(--ff-header-offset) + var(--ff-safe-top));
  }

  :where(
    a,
    button,
    [role="button"],
    summary,
    input[type="submit"],
    input[type="button"],
    input[type="reset"],
    label[for]
  ) {
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  ::selection {
    background: rgb(14 165 233 / 0.2);
    color: inherit;
  }

  :focus-visible {
    outline: 2px solid transparent;
    box-shadow: var(--ff-shadow-focus);
  }

  [hidden] {
    display: none !important;
  }

  .ff-root[data-theme="dark"] .ff-storyPoster__play,
  .ff-root[data-theme="dark"] .ff-teamCard__summary,
  .ff-root[data-theme="dark"] .ff-teamStat__value,
  .ff-root[data-theme="dark"] .ff-chip__amt,
  .ff-root[data-theme="dark"] .ff-impactChoice__amt {
    color: var(--ff-text);
  }

  @media (prefers-reduced-motion: reduce) {
    html.ff-root {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
}

/* ==========================================================================
   LAYOUT + COMMON COMPONENTS
   ========================================================================== */
@layer ff.layout {
  .ff-shell {
    position: relative;
    isolation: isolate;
  }

  .ff-shellBg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    background:
      radial-gradient(circle at 14% 6%, var(--ff-bg-glow-a), transparent 20rem),
      radial-gradient(circle at 84% 0%, var(--ff-bg-glow-b), transparent 20rem);
  }

  .ff-container {
    width: min(100% - 1.25rem, var(--ff-max));
    margin-inline: auto;
  }

  .ff-main {
    position: relative;
    padding-bottom: calc(var(--ff-tabs-offset) + 1.25rem + var(--ff-safe-bottom));
  }

  .ff-section {
    position: relative;
    padding-block: var(--ff-space-section);
  }

  @supports (content-visibility: auto) {
    .ff-section:not(.ff-section--hero) {
      content-visibility: auto;
      contain-intrinsic-size: auto 800px;
    }
  }

  .ff-section--hero {
    padding-top: 0.9rem;
  }

  .ff-row {
    display: flex;
    gap: var(--ff-3);
  }

  .ff-row--between {
    justify-content: space-between;
  }

  .ff-wrap {
    flex-wrap: wrap;
  }

  .ff-ais {
    align-items: center;
  }

  .ff-stack {
    display: grid;
    gap: var(--ff-space-card);
  }

  .ff-grid,
  .ff-hero__grid,
  .ff-impactLayout,
  .ff-storyGrid,
  .ff-checkoutLayout,
  .ff-footerGrid,
  .ff-teamGrid,
  .ff-impactTierGrid,
  .ff-impactChoiceGrid {
    display: grid;
    gap: var(--ff-space-grid);
  }

  .ff-grid--2,
  .ff-grid--3,
  .ff-teamGrid,
  .ff-impactTierGrid,
  .ff-impactChoiceGrid,
  .ff-footerGrid {
    grid-template-columns: 1fr;
  }

  .ff-minw-0 {
    min-width: 0 !important;
  }

  .ff-w-100 {
    width: 100% !important;
  }

  .ff-nounderline {
    text-decoration: none;
  }

  .ff-nowrap {
    white-space: nowrap;
  }

  .ff-pad {
    padding: clamp(0.95rem, 0.9rem + 0.35vw, 1.15rem);
  }

  .ff-gap-2 {
    gap: var(--ff-2);
  }

  .ff-gap-3 {
    gap: var(--ff-3);
  }

  .ff-m-0 {
    margin: 0 !important;
  }

  .ff-mt-0 {
    margin-top: 0 !important;
  }

  .ff-mt-1 {
    margin-top: var(--ff-1) !important;
  }

  .ff-mt-2 {
    margin-top: var(--ff-2) !important;
  }

  .ff-mt-3 {
    margin-top: var(--ff-3) !important;
  }

  .ff-mt-4 {
    margin-top: var(--ff-4) !important;
  }

  .ff-mb-0 {
    margin-bottom: 0 !important;
  }

  .ff-mb-2 {
    margin-bottom: var(--ff-2) !important;
  }

  .ff-num {
    font-variant-numeric: tabular-nums lining-nums;
    font-feature-settings: "tnum" 1, "lnum" 1;
  }

  .ff-skiplinks {
    position: absolute;
    inset: 0 auto auto 0;
    z-index: 1500;
    pointer-events: none;
  }

  .ff-skip {
    position: absolute;
    left: max(var(--ff-3), calc(var(--ff-3) + var(--ff-safe-left)));
    top: calc(var(--ff-3) + var(--ff-safe-top));
    transform: translateY(-160%);
    pointer-events: auto;
    padding: 0.7rem 0.95rem;
    border: 1px solid var(--ff-border-strong);
    border-radius: var(--ff-pill);
    background: var(--ff-panel-solid);
    color: var(--ff-text);
    text-decoration: none;
    box-shadow: var(--ff-shadow-2);
    transition: transform var(--ff-ease-emph);
  }

  .ff-skip:focus-visible {
    transform: translateY(0);
  }

  .ff-display,
  .ff-h2,
  .ff-h3,
  .ff-modal__title {
    margin: 0;
    letter-spacing: -0.025em;
    color: var(--ff-text);
    text-wrap: balance;
  }

  .ff-display {
    font-size: var(--ff-display-size);
    line-height: 0.95;
    font-weight: 800;
    max-width: 12ch;
  }

  .ff-h2,
  .ff-modal__title {
    font-size: var(--ff-h2-size);
    line-height: 1.08;
    font-weight: 760;
  }

  .ff-h3 {
    font-size: var(--ff-h3-size);
    line-height: 1.18;
    font-weight: 720;
  }

  .ff-lead {
    margin: 0;
    max-width: 62ch;
    font-size: clamp(1rem, 1rem + 0.15vw, 1.075rem);
    line-height: 1.66;
    color: var(--ff-text-soft);
    text-wrap: pretty;
  }

  .ff-kicker,
  .ff-label,
  .ff-footerNav__title,
  .ff-impactChoice__eyebrow,
  .ff-progressMini__label,
  .ff-teamStat__label,
  .ff-topbarGoal__label,
  .ff-topbarGoal__progressLabel {
    margin: 0;
    font-size: 0.74rem;
    line-height: 1.2;
    letter-spacing: 0.08em;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--ff-text-faint);
  }

  .ff-help,
  .ff-brand__sub,
  .ff-storyQuote__meta,
  .ff-progressMini__note,
  .ff-chip__meta,
  .ff-impactChoice__meta,
  .ff-drawer__trustText,
  .ff-backtotop__text {
    font-size: 0.93rem;
    line-height: 1.5;
  }

  .ff-muted,
  .ff-help.ff-muted,
  .ff-brand__sub,
  .ff-storyQuote__meta,
  .ff-progressMini__note,
  .ff-chip__meta,
  .ff-impactChoice__meta,
  .ff-drawer__trustText {
    color: var(--ff-text-muted);
  }

  .ff-link,
  .ff-footer__link {
    color: var(--ff-accent);
    text-decoration: none;
  }

  .ff-link:hover,
  .ff-footer__link:hover {
    color: var(--ff-brand-strong);
  }

  .ff-divider {
    margin: 0;
    border: 0;
    border-top: 1px solid var(--ff-line);
  }
}

@layer ff.components {
  .ff-sr,
  .ff-focus-probe,
  #ff_focus_probe {
    position: absolute !important;
    inline-size: 1px !important;
    block-size: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    clip-path: inset(50%) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  .ff-card,
  .ff-glass,
  .ff-surface,
  .ff-proofMini,
  .ff-progressMini,
  .ff-callout,
  .ff-topbar__capsule,
  .ff-topbarGoal,
  .ff-hero__capsule,
  .ff-checkoutShell,
  .ff-footerShell,
  .ff-drawer__panel,
  .ff-sheet__panel,
  .ff-modal__panel,
  .ff-teamCard,
  .ff-sponsorCell,
  .ff-impactTier,
  .ff-checkoutCard,
  .ff-storyPoster,
  .ff-disclosure {
    position: relative;
    border: 1px solid var(--ff-border);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.08), rgb(255 255 255 / 0)),
      var(--ff-panel-strong);
    box-shadow: var(--ff-shadow-1);
  }

  .ff-glass,
  .ff-surface,
  .ff-topbar__capsule,
  .ff-topbarGoal,
  .ff-hero__capsule,
  .ff-checkoutShell,
  .ff-footerShell,
  .ff-drawer__panel,
  .ff-sheet__panel,
  .ff-modal__panel {
    -webkit-backdrop-filter: blur(var(--ff-blur)) saturate(1.06);
    backdrop-filter: blur(var(--ff-blur)) saturate(1.06);
  }

  .ff-card,
  .ff-glass,
  .ff-surface,
  .ff-checkoutShell,
  .ff-footerShell,
  .ff-drawer__panel,
  .ff-sheet__panel,
  .ff-modal__panel,
  .ff-teamCard,
  .ff-impactTier,
  .ff-sponsorCell,
  .ff-checkoutCard,
  .ff-disclosure,
  .ff-storyPoster {
    border-radius: var(--ff-radius-3);
  }

  .ff-topbarGoal,
  .ff-navPill,
  .ff-pill,
  .ff-btn--pill,
  .ff-chip--pill,
  .ff-tab--pill {
    border-radius: var(--ff-pill);
  }

  .ff-proofMini,
  .ff-progressMini,
  .ff-callout {
    padding: 0.88rem 0.96rem;
    border-radius: var(--ff-radius-2);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.06), rgb(255 255 255 / 0)),
      var(--ff-panel);
  }

  .ff-proofMini strong,
  .ff-progressMini__value,
  .ff-teamStat__value,
  .ff-chip__amt,
  .ff-impactChoice__amt,
  .ff-topbarGoal__raised,
  .ff-topbarGoal__goal,
  .ff-topbarGoal__percent {
    color: var(--ff-text);
    font-weight: 780;
  }

  .ff-card--premium,
  .ff-impactTier--premium,
  .ff-impactPick--premium,
  .ff-impactProof--premium,
  .ff-impactChoice--feature,
  .ff-successUpsell,
  .ff-checkoutCard--summary,
  .is-featured {
    border-color: rgb(249 115 22 / 0.2);
    background:
      linear-gradient(180deg, rgb(249 115 22 / 0.08), rgb(249 115 22 / 0)),
      linear-gradient(180deg, rgb(255 255 255 / 0.08), rgb(255 255 255 / 0)),
      var(--ff-panel-strong);
  }

  .ff-card--lift,
  .ff-impactTier--recommended {
    box-shadow:
      0 0 0 1px rgb(249 115 22 / 0.08),
      var(--ff-shadow-2);
  }

  .ff-disclosure[open],
  .ff-teamCard:focus-within,
  .ff-impactTier:focus-within,
  .ff-sponsorCell:focus-within,
  .ff-checkoutCard:focus-within {
    border-color: rgb(14 165 233 / 0.28);
    box-shadow:
      0 0 0 1px rgb(14 165 233 / 0.1),
      var(--ff-shadow-2);
  }

  .ff-btn,
  .ff-tab,
  .ff-drawer__link,
  .ff-nav__link,
  .ff-footer__link--button,
  .ff-iconbtn,
  .ff-chip,
  .ff-themeToggle {
    transition:
      transform var(--ff-ease),
      background-color var(--ff-ease),
      border-color var(--ff-ease),
      box-shadow var(--ff-ease),
      color var(--ff-ease),
      opacity var(--ff-ease);
  }

  .ff-btn,
  .ff-tab,
  .ff-drawer__link,
  .ff-nav__link,
  .ff-footer__link--button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 2.7rem;
    padding: 0.68rem 1rem;
    border: 1px solid var(--ff-border);
    border-radius: var(--ff-pill);
    background: var(--ff-panel-solid);
    color: var(--ff-text);
    font-weight: 700;
    text-decoration: none;
    line-height: 1.1;
    white-space: nowrap;
  }

  .ff-btn--sm {
    min-height: 2.3rem;
    padding: 0.54rem 0.84rem;
    font-size: 0.92rem;
  }

  .ff-btn--lg {
    min-height: 2.95rem;
    padding: 0.82rem 1.12rem;
  }

  .ff-btn--primary,
  .ff-donate-btn,
  .ff-tab--cta {
    border-color: transparent;
    color: var(--ff-inverse);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.12), rgb(255 255 255 / 0)),
      linear-gradient(180deg, var(--ff-brand), var(--ff-brand-strong));
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.14),
      0 10px 22px rgb(249 115 22 / 0.2);
  }

  .ff-btn--secondary,
  .ff-btn--ghost,
  .ff-tab,
  .ff-nav__link,
  .ff-drawer__link,
  .ff-footer__link--button,
  .ff-iconbtn,
  .ff-chip,
  .ff-themeToggle {
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.07), rgb(255 255 255 / 0)),
      var(--ff-panel);
    color: var(--ff-text-soft);
  }

  .ff-btn--ghost {
    background: transparent;
  }

  .ff-btn:disabled,
  .ff-chip:disabled,
  .ff-tab:disabled,
  .ff-iconbtn:disabled,
  .ff-input:disabled,
  .ff-themeToggle:disabled {
    opacity: 0.58;
    cursor: not-allowed;
    pointer-events: none;
    transform: none;
    box-shadow: none;
  }

  .ff-iconbtn,
  .ff-themeToggle {
    display: inline-grid;
    place-items: center;
    inline-size: 2.45rem;
    block-size: 2.45rem;
    min-inline-size: 2.45rem;
    padding: 0;
    border: 1px solid var(--ff-border);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.07), rgb(255 255 255 / 0)),
      var(--ff-panel);
  }

  .ff-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
