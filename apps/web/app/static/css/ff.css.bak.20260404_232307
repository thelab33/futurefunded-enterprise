    background: rgb(2 6 23 / 0.64);
    opacity: 0;
    transition: opacity var(--ff-ease);
    pointer-events: auto;
  }

  .ff-sheet__panel,
  .ff-modal__panel {
    position: relative;
    width: 100%;
    opacity: 0;
    transform: translateY(1.25rem);
    transition:
      opacity var(--ff-ease),
