    setHidden(checkoutEls.stageSuccess, !isSuccess);
    if (checkoutEls.stageForm) checkoutEls.stageForm.dataset.state = isSuccess ? "hidden" : "visible";
    if (checkoutEls.stageSuccess) checkoutEls.stageSuccess.dataset.state = isSuccess ? "visible" : "hidden";
  }

  function validateCheckoutForm() {
    if (!checkoutEls.form || !checkoutEls.amountInput || !checkoutEls.donorName || !checkoutEls.donorEmail) {
      return false;
    }

    const amount = Number(checkoutEls.amountInput.value || 0);
    let valid = true;
    let firstInvalid = null;

    const checks = [
      [checkoutEls.amountInput, amount >= 1],
      [checkoutEls.donorName, checkoutEls.donorName.value.trim().length >= 2],
      [checkoutEls.donorEmail, /\S+@\S+\.\S+/.test(checkoutEls.donorEmail.value.trim())],
    ];

    checks.forEach(([field, ok]) => {
      if (!field) return;
      field.setAttribute("aria-invalid", ok ? "false" : "true");
      if (!ok && !firstInvalid) firstInvalid = field;
      valid = valid && ok;
    });

    if (!valid) {
      showMessage(checkoutEls.error, "Please review the amount, name, and email, then try again.");
      firstInvalid?.focus?.();
      announce("Please review the amount, name, and email, then try again.");
    } else {
      showMessage(checkoutEls.error, "");
    }

    return valid;
  }

