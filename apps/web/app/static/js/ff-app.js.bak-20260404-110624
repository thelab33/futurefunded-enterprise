      return;
    }

    const openOnboard = target.closest(hooks.openOnboard || "");
    if (openOnboard) {
      event.preventDefault();
      openOverlay("onboard", openOnboard);
      updateOnboardStep(1);
      return;
    }

    const closeCheckout = target.closest(hooks.closeCheckout || "");
    if (closeCheckout) {
      event.preventDefault();
      closeOverlay("checkout");
      return;
    }

    const closeDrawer = target.closest(hooks.closeDrawer || "");
    if (closeDrawer) {
      event.preventDefault();
      closeOverlay("drawer");
      return;
    }

    const closeSponsor = target.closest(hooks.closeSponsor || "");
    if (closeSponsor) {
      event.preventDefault();
      closeOverlay("sponsor");
      return;
    }

    const closeVideo = target.closest(hooks.closeVideo || "");
    if (closeVideo) {
      event.preventDefault();
      closeOverlay("video");
      return;
    }

    const closeTerms = target.closest(hooks.closeTerms || "");
    if (closeTerms) {
      event.preventDefault();
      closeOverlay("terms");
      return;
    }

    const closePrivacy = target.closest(hooks.closePrivacy || "");
    if (closePrivacy) {
      event.preventDefault();
      closeOverlay("privacy");
      return;
    }

    const closeOnboard = target.closest(hooks.closeOnboard || "");
    if (closeOnboard) {
      event.preventDefault();
      closeOverlay("onboard");
      return;
    }

    const share = target.closest(hooks.share || "");
    if (share) {
      handleShare(event);
      return;
    }

    const themeToggle = target.closest(hooks.themeToggle || "");
    if (themeToggle) {
      event.preventDefault();
      applyTheme(root.getAttribute("data-theme") === "dark" ? "light" : "dark");
      return;
    }

    const amountChip = target.closest(hooks.amountChip || "");
    if (amountChip) {
      event.preventDefault();
      const amount = Number(amountChip.getAttribute("data-ff-amount") || 0);
      preloadCheckout({ amount });

      if (checkoutEls.amountInput && overlayState.activeKey !== "checkout") {
        openOverlay("checkout", amountChip);
      }
      return;
    }

    const sponsorTier = target.closest(hooks.sponsorTier || "");
    if (sponsorTier) {
      event.preventDefault();
      selectSponsorTier(sponsorTier.getAttribute("data-ff-sponsor-tier") || "");
      return;
    }

    const stepPill = target.closest(hooks.stepPill || "");
    if (stepPill) {
      event.preventDefault();
      updateOnboardStep(stepPill.getAttribute("data-ff-step-pill") || "1");
      return;
    }

    const successShare = target.closest("[data-ff-success-share]");
    if (successShare) {
      handleShare(event);
      return;
    }

    const successCopy = target.closest("[data-ff-success-copy]");
    if (successCopy) {
      event.preventDefault();
      copyText(meta.shareUrl)
        .then(() => toast("Fundraiser link copied."))
        .catch(() => toast("Unable to copy the fundraiser link."));
    }
  });

  if (checkoutEls.amountInput) {
    checkoutEls.amountInput.addEventListener("input", () => {
      syncAmountUI(checkoutEls.amountInput.value);
      debounceIntentRefresh();
    });
  }

  if (checkoutEls.form) {
    checkoutEls.form.addEventListener("submit", handleCheckoutSubmit);
  }

  if (sponsorEls.tierButtons.length) {
    selectSponsorTier("");
  }

  if (onboardEls.form) {
    onboardEls.form.addEventListener("input", () => {
      updateOnboardSwatches();
      if (currentOnboardStep === onboardEls.panels.length) {
        buildOnboardingSummary();
      }
    });

    onboardEls.form.addEventListener("submit", (event) => {
      event.preventDefault();
      submitOnboarding();
    });
  }

  if (onboardEls.prev) {
    onboardEls.prev.addEventListener("click", () => updateOnboardStep(currentOnboardStep - 1));
  }

  if (onboardEls.next) {
    onboardEls.next.addEventListener("click", () => updateOnboardStep(currentOnboardStep + 1));
  }

  if (onboardEls.finish) {
    onboardEls.finish.addEventListener("click", (event) => {
      event.preventDefault();
      submitOnboarding();
    });
  }

  if (onboardEls.copy) {
    onboardEls.copy.addEventListener("click", async () => {
      const brief = buildOnboardingSummary();
      try {
        await copyText(brief);
        toast("Launch brief copied.");
      } catch (_err) {
        toast("Unable to copy the launch brief.");
      }
    });
  }

  if (onboardEls.email) {
    onboardEls.email.addEventListener("click", () => {
      const target =
        onboardEls.email?.getAttribute("data-ff-onboard-email-target") ||
        "hello@getfuturefunded.com";
      const brief = encodeURIComponent(buildOnboardingSummary());
      const subject = encodeURIComponent("FutureFunded launch brief");
      window.location.href = `mailto:${encodeURIComponent(target)}?subject=${subject}&body=${brief}`;
    });
  }

  if (uiEls.backToTop) {
    uiEls.backToTop.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }

  window.addEventListener(
    "scroll",
    () => {
      updateBackToTop();
      updateFloatingDonate();
    },
    { passive: true }
  );

  window.addEventListener("resize", updateFloatingDonate);

  function initHashOpen() {
    const hash = window.location.hash.replace(/^#/, "");
    if (!hash) return;

    if (hash === "checkout") {
      openOverlay("checkout");
      mountStripeForCurrentAmount(false);
      renderPayPalButtons();
    } else if (hash === "sponsor-interest") {
      openOverlay("sponsor");
    } else if (hash === "press-video") {
      openOverlay("video");
    } else if (hash === "terms") {
      openOverlay("terms");
    } else if (hash === "privacy") {
      openOverlay("privacy");
    } else if (hash === "ff-onboarding") {
      openOverlay("onboard");
      updateOnboardStep(1);
    }
  }

  if (window.matchMedia) {
    const media = window.matchMedia("(prefers-color-scheme: dark)");
    if (media && media.addEventListener) {
      media.addEventListener("change", (event) => {
        let stored = "";
        try {
          stored = window.localStorage.getItem("ff-theme") || window.localStorage.getItem("ff.theme") || "";
        } catch (_err) {}
        if (stored === "dark" || stored === "light") return;
        applyTheme(event.matches ? "dark" : "light", false);
      });
    }
  }

  initTheme();
  syncAmountUI(checkoutEls.amountInput?.value || 0);
  updateBackToTop();
  updateFloatingDonate();
  initScrollSpy();
  populateSponsorWall();
  initMediaFallbacks();
  updateOnboardSwatches();
  updateOnboardStep(1);
  hydrateSuccessFromUrl();
  initHashOpen();

  if (overlays.checkout.container?.hasAttribute("data-ff-stripe-preload")) {
    mountStripeForCurrentAmount(false);
    renderPayPalButtons();
  }
})();


