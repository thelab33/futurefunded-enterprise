    if (!checkoutEls.form) return;

    const amount = Number(options.amount || checkoutEls.amountInput?.value || 0);
    const teamId = options.teamId || checkoutEls.hiddenTeamId?.value || "default";
    const playerId = options.playerId || checkoutEls.hiddenPlayerId?.value || "";
    const sponsorAmount = options.sponsorAmount || "";

    if (checkoutEls.amountInput && amount > 0) {
      checkoutEls.amountInput.value = String(amount);
    }
    if (checkoutEls.hiddenTeamId) checkoutEls.hiddenTeamId.value = teamId || "default";
    if (checkoutEls.hiddenPlayerId) checkoutEls.hiddenPlayerId.value = playerId || "";
    if (checkoutEls.hiddenSponsorAmount) {
